<IfModule mod_security.c>
    # GoDaddy's OWASP CRS WAF false-positives on this app's authenticated admin
    # requests (certain record UUIDs in admin URLs), blocking them as a 404 via
    # the docroot error document. We can't reach the WAF audit log on shared
    # hosting to target the exact rule, so disable the inbound CRS rule range for
    # this app. (Laravel parameterizes every query via Eloquent and escapes output
    # via Blade, so these CRS rules add little here.) This host only honors
    # SecRuleRemoveById in .htaccess — SecRuleEngine/<If> returns a 405.
    # 920000-949999 = inbound (request) rules; 950000-959999 = outbound (response)
    # rules. The field sheet renders record data that trips an OUTBOUND rule for
    # certain inquiries, so both directions must be excluded.
    SecRuleRemoveById "920000-959999"
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
